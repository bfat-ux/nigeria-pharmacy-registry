# Copy to .env and fill in your values. Never commit .env.
# NPR API (for gateway to call your local API)
NPR_API_URL=http://localhost:8000
NPR_API_KEY=

# Africa's Talking (for sending SMS and receiving webhooks)
AT_USERNAME=sandbox
AT_API_KEY=
# AT_SENDER_ID=   # optional, if you have a registered sender ID

# Optional: for inbound SMS webhook (set in AT dashboard to point to your server)
# SMS_WEBHOOK_SECRET=
